<div class="flex align-center gap-half pad-inline">
  <%= user.name %>
  <hr class="flex-item-grow margin-none">

  <% if Current.user.can_administer? && user != Current.user %>
    <label class="btn txt-small">
      <input type="checkbox">
      <%= image_tag "crown.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Admin</span>
    </label>

    <%= button_to user_path(user), method: :delete, class: "btn btn--negative txt-small", data: {
          turbo_confirm: "Are you sure you want to permanently remove this person from the account? This can’t be undone."} do %>
      <%= image_tag "minus.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Remove <%= user.name %> from the account</span>
    <% end %>
  <% end %>
</div>
